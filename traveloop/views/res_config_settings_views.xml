<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="action_traveloop_config_settings" model="ir.actions.act_window">
        <field name="name">Traveloop Settings</field>
        <field name="res_model">res.config.settings</field>
        <field name="view_mode">form</field>
        <field name="target">inline</field>
        <field name="context">{'module': 'traveloop'}</field>
    </record>

    <record id="view_traveloop_config_settings" model="ir.ui.view">
        <field name="name">res.config.settings.view.form.inherit.traveloop</field>
        <field name="model">res.config.settings</field>
        <field name="inherit_id" ref="base.res_config_settings_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//form" position="inside">
                <app data-string="Traveloop" string="Traveloop" groups="traveloop.group_travel_manager">
                    <block title="General Settings">
                        <setting string="Default Currency" help="Default currency for travel budgets">
                            <field name="travel_default_currency_id"/>
                        </setting>
                        <setting string="Public Sharing" help="Allow users to share their trips publicly">
                            <field name="travel_allow_public_sharing"/>
                        </setting>
                        <setting string="Max Stops" help="Maximum number of stops per trip">
                            <field name="travel_max_stops_per_trip"/>
                        </setting>
                    </block>
                </app>
            </xpath>
        </field>
    </record>
</odoo>
