<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="view_travel_expense_form" model="ir.ui.view">
        <field name="name">travel.expense.form</field>
        <field name="model">travel.expense</field>
        <field name="arch" type="xml">
            <form string="Expense">
                <sheet>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="trip_id"/>
                            <field name="stop_id" domain="[('trip_id', '=', trip_id)]"/>
                            <field name="category"/>
                        </group>
                        <group>
                            <field name="date"/>
                            <field name="amount"/>
                            <field name="currency_id" invisible="1"/>
                            <field name="payment_method"/>
                        </group>
                    </group>
                    <field name="notes" placeholder="Notes..."/>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_travel_expense_list" model="ir.ui.view">
        <field name="name">travel.expense.list</field>
        <field name="model">travel.expense</field>
        <field name="arch" type="xml">
            <list string="Expenses" editable="bottom">
                <field name="date"/>
                <field name="category"/>
                <field name="name"/>
                <field name="trip_id"/>
                <field name="stop_id" domain="[('trip_id', '=', trip_id)]" optional="show"/>
                <field name="amount" sum="Total"/>
                <field name="payment_method"/>
                <field name="currency_id" invisible="1"/>
            </list>
        </field>
    </record>

    <record id="view_travel_expense_pivot" model="ir.ui.view">
        <field name="name">travel.expense.pivot</field>
        <field name="model">travel.expense</field>
        <field name="arch" type="xml">
            <pivot string="Expense Analysis">
                <field name="category" type="row"/>
                <field name="amount" type="measure"/>
            </pivot>
        </field>
    </record>

    <record id="view_travel_expense_graph" model="ir.ui.view">
        <field name="name">travel.expense.graph</field>
        <field name="model">travel.expense</field>
        <field name="arch" type="xml">
            <graph string="Expense Breakdown" type="pie">
                <field name="category" type="row"/>
                <field name="amount" type="measure"/>
            </graph>
        </field>
    </record>

    <record id="view_travel_expense_search" model="ir.ui.view">
        <field name="name">travel.expense.search</field>
        <field name="model">travel.expense</field>
        <field name="arch" type="xml">
            <search string="Search Expenses">
                <field name="name"/>
                <field name="trip_id"/>
                <field name="category"/>
                <group>
                    <filter string="Category" name="group_cat" context="{'group_by': 'category'}"/>
                    <filter string="Trip" name="group_trip" context="{'group_by': 'trip_id'}"/>
                    <filter string="Date" name="group_date" context="{'group_by': 'date:month'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="action_travel_expense" model="ir.actions.act_window">
        <field name="name">Expenses</field>
        <field name="res_model">travel.expense</field>
        <field name="view_mode">list,form,pivot,graph</field>
        <field name="search_view_id" ref="view_travel_expense_search"/>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">Track your travel expenses!</p>
        </field>
    </record>
</odoo>
