<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="view_travel_activity_form" model="ir.ui.view">
        <field name="name">travel.activity.form</field>
        <field name="model">travel.activity</field>
        <field name="arch" type="xml">
            <form string="Activity">
                <sheet>
                    <field name="image" widget="image" class="oe_avatar"/>
                    <div class="oe_title">
                        <h1><field name="name" placeholder="e.g. Visit Eiffel Tower"/></h1>
                    </div>
                    <group>
                        <group>
                            <field name="activity_type"/>
                            <field name="city_id"/>
                            <field name="stop_id"/>
                            <field name="date"/>
                            <field name="time_start" widget="float_time"/>
                            <field name="time_end" widget="float_time"/>
                            <field name="duration_hours"/>
                        </group>
                        <group>
                            <field name="cost"/>
                            <field name="cost_level"/>
                            <field name="rating"/>
                            <field name="is_booked"/>
                            <field name="booking_reference" invisible="not is_booked"/>
                            <field name="address"/>
                            <field name="website" widget="url"/>
                        </group>
                    </group>
                    <field name="description" placeholder="Describe this activity..."/>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_travel_activity_list" model="ir.ui.view">
        <field name="name">travel.activity.list</field>
        <field name="model">travel.activity</field>
        <field name="arch" type="xml">
            <list string="Activities">
                <field name="name"/>
                <field name="activity_type"/>
                <field name="city_id"/>
                <field name="stop_id" optional="show"/>
                <field name="date"/>
                <field name="time_start" widget="float_time"/>
                <field name="cost" sum="Total"/>
                <field name="cost_level"/>
                <field name="rating"/>
                <field name="is_booked"/>
            </list>
        </field>
    </record>

    <record id="view_travel_activity_kanban" model="ir.ui.view">
        <field name="name">travel.activity.kanban</field>
        <field name="model">travel.activity</field>
        <field name="arch" type="xml">
            <kanban class="o_kanban_small_column" sample="1">
                <field name="name"/>
                <field name="activity_type"/>
                <field name="cost"/>
                <field name="rating"/>
                <field name="city_id"/>
                <field name="image"/>
                <templates>
                    <t t-name="card">
                        <div t-if="record.image.raw_value" class="mb-2">
                            <field name="image" widget="image" options='{"preview_image": "image"}'/>
                        </div>
                        <div class="fw-bold"><field name="name"/></div>
                        <div class="text-muted small">
                            <field name="activity_type"/> · <field name="city_id"/>
                        </div>
                        <div class="d-flex justify-content-between mt-1">
                            <span class="badge text-bg-primary"><field name="cost"/></span>
                            <span t-if="record.rating.raw_value">Rating: <field name="rating"/></span>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <record id="view_travel_activity_search" model="ir.ui.view">
        <field name="name">travel.activity.search</field>
        <field name="model">travel.activity</field>
        <field name="arch" type="xml">
            <search string="Search Activities">
                <field name="name"/>
                <field name="city_id"/>
                <field name="activity_type"/>
                <filter string="Free" name="free" domain="[('cost', '=', 0)]"/>
                <filter string="Budget" name="budget" domain="[('cost', '&lt;', 25)]"/>
                <filter string="Booked" name="booked" domain="[('is_booked', '=', True)]"/>
                <group>
                    <filter string="Type" name="group_type" context="{'group_by': 'activity_type'}"/>
                    <filter string="City" name="group_city" context="{'group_by': 'city_id'}"/>
                    <filter string="Cost Level" name="group_cost" context="{'group_by': 'cost_level'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="action_travel_activity" model="ir.actions.act_window">
        <field name="name">Trip Activities</field>
        <field name="res_model">travel.activity</field>
        <field name="view_mode">list,kanban,form</field>
        <field name="search_view_id" ref="view_travel_activity_search"/>
        <field name="domain">[('stop_id', '!=', False)]</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">Add activities to your stops!</p>
        </field>
    </record>

    <record id="action_travel_activity_catalog" model="ir.actions.act_window">
        <field name="name">Activity Catalog</field>
        <field name="res_model">travel.activity</field>
        <field name="view_mode">kanban,list,form</field>
        <field name="search_view_id" ref="view_travel_activity_search"/>
        <field name="domain">[('stop_id', '=', False)]</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">Discover activities!</p>
        </field>
    </record>
</odoo>
