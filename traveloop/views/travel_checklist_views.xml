<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="view_travel_checklist_form" model="ir.ui.view">
        <field name="name">travel.checklist.item.form</field>
        <field name="model">travel.checklist.item</field>
        <field name="arch" type="xml">
            <form string="Checklist Item">
                <sheet>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="category"/>
                            <field name="quantity"/>
                        </group>
                        <group>
                            <field name="trip_id"/>
                            <field name="is_packed"/>
                        </group>
                    </group>
                    <field name="notes" placeholder="Additional notes..."/>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_travel_checklist_list" model="ir.ui.view">
        <field name="name">travel.checklist.item.list</field>
        <field name="model">travel.checklist.item</field>
        <field name="arch" type="xml">
            <list string="Packing Checklist" editable="bottom"
                  decoration-success="is_packed"
                  decoration-muted="is_packed">
                <field name="sequence" widget="handle"/>
                <field name="is_packed" widget="boolean_toggle"/>
                <field name="category"/>
                <field name="name"/>
                <field name="quantity"/>
                <field name="trip_id"/>
                <field name="notes"/>
            </list>
        </field>
    </record>

    <record id="view_travel_checklist_search" model="ir.ui.view">
        <field name="name">travel.checklist.item.search</field>
        <field name="model">travel.checklist.item</field>
        <field name="arch" type="xml">
            <search string="Search Checklist">
                <field name="name"/>
                <field name="trip_id"/>
                <filter string="Packed" name="packed" domain="[('is_packed', '=', True)]"/>
                <filter string="Not Packed" name="not_packed" domain="[('is_packed', '=', False)]"/>
                <group>
                    <filter string="Category" name="group_category" context="{'group_by': 'category'}"/>
                    <filter string="Trip" name="group_trip" context="{'group_by': 'trip_id'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="action_travel_checklist" model="ir.actions.act_window">
        <field name="name">Packing Checklist</field>
        <field name="res_model">travel.checklist.item</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_travel_checklist_search"/>
        <field name="context">{'search_default_not_packed': 1}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">Start your packing list!</p>
        </field>
    </record>
</odoo>
