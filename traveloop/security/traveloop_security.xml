<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <data noupdate="0">
        <!-- Privilege for Traveloop groups -->
        <record model="res.groups.privilege" id="privilege_traveloop">
            <field name="name">Traveloop</field>
            <field name="sequence">50</field>
            <field name="category_id" ref="base.module_category_services"/>
        </record>

        <!-- User Group: Travel Planner (regular user) -->
        <record id="group_travel_planner" model="res.groups">
            <field name="name">Travel Planner</field>
            <field name="sequence">10</field>
            <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
            <field name="privilege_id" ref="privilege_traveloop"/>
        </record>

        <!-- User Group: Travel Manager (admin) -->
        <record id="group_travel_manager" model="res.groups">
            <field name="name">Travel Manager</field>
            <field name="sequence">20</field>
            <field name="privilege_id" ref="privilege_traveloop"/>
            <field name="implied_ids" eval="[(4, ref('group_travel_planner'))]"/>
            <field name="user_ids" eval="[(4, ref('base.user_root')), (4, ref('base.user_admin'))]"/>
        </record>
    </data>

    <data noupdate="1">
        <!-- Record Rules -->
        <record id="travel_trip_rule_planner" model="ir.rule">
            <field name="name">Travel Trip: planner sees own trips</field>
            <field name="model_id" ref="model_travel_trip"/>
            <field name="domain_force">[('user_id', '=', user.id)]</field>
            <field name="groups" eval="[(4, ref('group_travel_planner'))]"/>
        </record>

        <record id="travel_trip_rule_manager" model="ir.rule">
            <field name="name">Travel Trip: manager sees all</field>
            <field name="model_id" ref="model_travel_trip"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="groups" eval="[(4, ref('group_travel_manager'))]"/>
        </record>
    </data>
</odoo>
